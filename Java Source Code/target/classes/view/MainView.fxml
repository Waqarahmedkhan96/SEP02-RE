<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="appRoot" xmlns:fx="http://javafx.com/fxml" fx:controller="view.MainViewController"
            style="-fx-background-color: #e6e6e6;">
    <top>
        <Label fx:id="breadcrumbLabel" text="Employee Start / Dashboard"
               style="-fx-padding: 15 0 10 6; -fx-text-fill: #8c8c8c; -fx-font-size: 16px;"/>
    </top>

    <center>
        <StackPane style="-fx-padding: 0 6 6 6;">
            <VBox fx:id="dashboardPage" spacing="28" alignment="TOP_CENTER"
                  style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 24 54 36 54;">
                <Label text="Welcome to EasyRide"
                       style="-fx-font-size: 27px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"
                       maxWidth="Infinity" alignment="CENTER"/>
                <Label text="Select an action to proceed:"
                       style="-fx-font-size: 13px; -fx-text-fill: #777777;"
                       maxWidth="Infinity" alignment="CENTER"/>

                <GridPane hgap="32" vgap="14" maxWidth="1200" style="-fx-padding: 44 0 18 0;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.33"/>
                        <ColumnConstraints percentWidth="33.33"/>
                        <ColumnConstraints percentWidth="33.33"/>
                    </columnConstraints>
                    <Button text="Customers" onAction="#showCustomers"
                            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                            maxWidth="Infinity" prefHeight="55" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Button text="Vehicles" onAction="#showVehicles"
                            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                            maxWidth="Infinity" prefHeight="55" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Button text="Bookings" onAction="#showBookings"
                            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                            maxWidth="Infinity" prefHeight="55" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                    <Label text="Customer's Management" style="-fx-text-fill: #888888;"
                           maxWidth="Infinity" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label text="Vehicle's Management" style="-fx-text-fill: #888888;"
                           maxWidth="Infinity" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Booking's Management" style="-fx-text-fill: #888888;"
                           maxWidth="Infinity" alignment="CENTER" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                </GridPane>

                <VBox spacing="8" maxWidth="1200">
                    <Label text="Today at a glance"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
                    <GridPane hgap="24" vgap="18"
                              style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 22 26 18 26;">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>
                        <VBox spacing="8" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Active bookings" style="-fx-text-fill: #777777;"/>
                            <Label fx:id="activeBookingsValueLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
                        </VBox>
                        <VBox spacing="8" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Available vehicles" style="-fx-text-fill: #777777;"/>
                            <Label fx:id="availableVehiclesValueLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #20964b;"/>
                        </VBox>
                        <VBox spacing="8" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Overdue returns" style="-fx-text-fill: #777777;"/>
                            <Label fx:id="overdueReturnsValueLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #c8202f;"/>
                        </VBox>
                        <VBox spacing="8" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="Completed today" style="-fx-text-fill: #777777;"/>
                            <Label fx:id="completedTodayValueLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2b61bf;"/>
                        </VBox>
                    </GridPane>
                </VBox>
            </VBox>

            <VBox fx:id="customerPage" visible="false" managed="false">
                <fx:include source="CustomerView.fxml"/>
            </VBox>
            <VBox fx:id="vehiclePage" visible="false" managed="false">
                <fx:include source="VehicleManagement.fxml"/>
            </VBox>
            <VBox fx:id="bookingPage" visible="false" managed="false">
                <fx:include source="BookingView.fxml"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
