<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="view.BookingViewController"
      style="-fx-padding: 20;">
    <GridPane hgap="10" vgap="10">
        <Label text="Customer ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="customerIdField" promptText="Customer ID" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Booking ID" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="bookingIdField" promptText="Select booking" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Vehicle ID" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="vehicleIdField" promptText="Vehicle ID" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Employee ID" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="employeeIdField" promptText="Employee ID" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Start Date" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <DatePicker fx:id="startDatePicker" promptText="yyyy-MM-dd" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="End Date" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <DatePicker fx:id="endDatePicker" promptText="yyyy-MM-dd" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Status" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <TextField fx:id="statusField" text="ACTIVE" promptText="ACTIVE" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Create Booking" onAction="#handleCreateBooking"/>
        <Button text="View Customer Bookings" onAction="#handleLoadBookings"/>
        <Button text="Search Active Bookings" onAction="#handleSearchActiveBookings"/>
        <Button text="Update Booking" onAction="#handleUpdateBooking"/>
    </HBox>

    <TableView fx:id="bookingsTable" prefHeight="320">
        <columns>
            <TableColumn fx:id="bookingIdColumn" text="Booking ID" prefWidth="90"/>
            <TableColumn fx:id="startDateColumn" text="Start" prefWidth="160"/>
            <TableColumn fx:id="endDateColumn" text="End" prefWidth="160"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
            <TableColumn fx:id="vehicleIdColumn" text="Vehicle ID" prefWidth="90"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel"/>
</VBox>
