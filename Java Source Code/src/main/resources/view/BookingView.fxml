<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="view.BookingViewController"
           style="-fx-background-color: #e6e6e6; -fx-padding: 18;">

    <VBox fx:id="menuPage" spacing="34" alignment="TOP_CENTER"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 32 42 32;">
        <HBox alignment="CENTER_LEFT" maxWidth="Infinity">
            <Button fx:id="menuBackButton" text="Back" onAction="#handleBackToDashboard"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                    prefWidth="82" prefHeight="30"/>
        </HBox>

        <VBox spacing="4" alignment="CENTER">
            <Label text="Bookings Management"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="Choose a booking workflow"
                   style="-fx-font-size: 13px; -fx-text-fill: #777777;"/>
        </VBox>

        <GridPane hgap="34" vgap="36" maxWidth="860">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>

            <VBox spacing="12" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Button text="Create Booking" onAction="#showCreateBooking"
                        style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                        maxWidth="Infinity" prefHeight="48"/>
                <Label text="New rental reservation" style="-fx-text-fill: #888888;"/>
            </VBox>

            <VBox spacing="12" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Button text="Update Booking" onAction="#showUpdateBooking"
                        style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                        maxWidth="Infinity" prefHeight="48"/>
                <Label text="Change vehicle, period, status" style="-fx-text-fill: #888888;"/>
            </VBox>

            <VBox spacing="12" alignment="CENTER" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Button text="Cancel Booking" onAction="#showCancelBooking"
                        style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                        maxWidth="Infinity" prefHeight="48"/>
                <Label text="Mark booking as cancelled" style="-fx-text-fill: #888888;"/>
            </VBox>

            <VBox spacing="12" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Button text="Complete / Return" onAction="#showCompleteBooking"
                        style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                        maxWidth="Infinity" prefHeight="48"/>
                <Label text="Close active booking" style="-fx-text-fill: #888888;"/>
            </VBox>

            <VBox spacing="12" alignment="CENTER" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Button text="Booking History" onAction="#showBookingHistory"
                        style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                        maxWidth="Infinity" prefHeight="48"/>
                <Label text="Read-only archive" style="-fx-text-fill: #888888;"/>
            </VBox>
        </GridPane>
    </VBox>

    <VBox fx:id="createPage" spacing="24" visible="false" managed="false"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 42 54;">
        <Button text="Back" onAction="#showBookingMenu"
                style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                prefWidth="86" prefHeight="34"/>

        <VBox spacing="6" alignment="CENTER">
            <Label text="Create Booking"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="Select customer, dates, then reserve an available vehicle"
                   style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
        </VBox>

        <GridPane hgap="18" vgap="14" maxWidth="1100">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="18"/>
                <ColumnConstraints percentWidth="21"/>
            </columnConstraints>

            <Label text="Customer ID" style="-fx-text-fill: #666666;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="customerComboBox" promptText="Select customer" maxWidth="Infinity" visibleRowCount="6"
                      GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="customerIdField" visible="false" managed="false" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

            <Label text="Start date" style="-fx-text-fill: #666666;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <DatePicker fx:id="startDatePicker" promptText="dd/mm/yyyy" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="End date" style="-fx-text-fill: #666666;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <DatePicker fx:id="endDatePicker" promptText="dd/mm/yyyy" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Label text="Employee ID" style="-fx-text-fill: #666666;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <ComboBox fx:id="employeeIdComboBox" promptText="Select employee" maxWidth="Infinity" visibleRowCount="3"
                      GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <TextField fx:id="employeeIdField" visible="false" managed="false" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Button text="Show Available Vehicles" onAction="#handleShowAvailableVehicles"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="42" GridPane.columnIndex="4" GridPane.rowIndex="1"/>

            <Label text="Filter by color" style="-fx-text-fill: #666666;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="colorFilterField" promptText="Any" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

            <Label text="Vehicle type" style="-fx-text-fill: #666666;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <TextField fx:id="vehicleTypeFilterField" promptText="Any" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Max price/day" style="-fx-text-fill: #666666;" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <TextField fx:id="maxPriceFilterField" promptText="DKK" GridPane.columnIndex="2" GridPane.rowIndex="3"/>

            <Label text="Status" style="-fx-text-fill: #666666;" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
            <TextField fx:id="vehicleStatusFilterField" text="Date-based" editable="false" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
        </GridPane>

        <TableView fx:id="createVehiclesTable" prefHeight="210" maxWidth="1100">
            <columns>
                <TableColumn fx:id="createVehicleIdColumn" text="ID" prefWidth="90"/>
                <TableColumn fx:id="createVehicleModelColumn" text="Vehicle" prefWidth="170"/>
                <TableColumn fx:id="createVehicleTypeColumn" text="Type" prefWidth="140"/>
                <TableColumn fx:id="createVehicleColorColumn" text="Color" prefWidth="140"/>
                <TableColumn fx:id="createVehiclePriceColumn" text="Price/hour" prefWidth="130"/>
                <TableColumn fx:id="createVehicleStatusColumn" text="Status" prefWidth="140"/>
            </columns>
        </TableView>

        <HBox alignment="CENTER_LEFT" spacing="12" maxWidth="1100">
            <Label text="Selected vehicle ID" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <TextField fx:id="vehicleIdField" promptText="Vehicle ID" prefWidth="150"/>
            <TextField fx:id="statusField" text="ACTIVE" visible="false" managed="false"/>
            <Label fx:id="selectedVehicleStatusLabel" text="Select vehicle" style="-fx-background-color: #eeeeee; -fx-text-fill: #777777; -fx-background-radius: 16; -fx-padding: 7 20 7 20; -fx-font-weight: bold;"/>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="18" maxWidth="1100">
            <Button text="Cancel" onAction="#showBookingMenu" prefWidth="128" prefHeight="42"/>
            <Button fx:id="confirmBookingButton" text="Confirm Booking" onAction="#handleCreateBooking"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 16px; -fx-font-weight: bold;"
                    prefWidth="166" prefHeight="42"/>
        </HBox>
    </VBox>

    <VBox fx:id="updatePage" spacing="24" visible="false" managed="false"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 42 54;">
        <Button text="Back" onAction="#showBookingMenu"
                style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                prefWidth="86" prefHeight="34"/>

        <VBox spacing="6" alignment="CENTER">
            <Label text="Update Booking"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="Search an active booking and save changed details"
                   style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
        </VBox>

        <HBox spacing="18" alignment="CENTER_LEFT" maxWidth="1100">
            <VBox spacing="6">
                <Label text="Search booking" style="-fx-text-fill: #666666;"/>
                <TextField fx:id="updateSearchField" promptText="Booking ID, customer, vehicle" prefWidth="330"/>
            </VBox>
            <Button text="Search" onAction="#handleSearchActiveBookings"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold;"
                    prefWidth="116" prefHeight="42"/>
        </HBox>

        <TableView fx:id="bookingsTable" prefHeight="170" maxWidth="1100">
            <columns>
                <TableColumn fx:id="bookingIdColumn" text="Booking ID" prefWidth="120"/>
                <TableColumn fx:id="startDateColumn" text="Start" prefWidth="180"/>
                <TableColumn fx:id="endDateColumn" text="End" prefWidth="180"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                <TableColumn fx:id="vehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
            </columns>
        </TableView>

        <VBox spacing="14" maxWidth="1100">
            <Label text="Edit selected booking" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <GridPane hgap="18" vgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <Label text="Booking ID" style="-fx-text-fill: #666666;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="bookingIdField" promptText="Select booking" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Vehicle ID" style="-fx-text-fill: #666666;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="updateVehicleIdField" promptText="Vehicle ID" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Start date" style="-fx-text-fill: #666666;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <DatePicker fx:id="updateStartDatePicker" promptText="dd/mm/yyyy" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                <Label text="End date" style="-fx-text-fill: #666666;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <DatePicker fx:id="updateEndDatePicker" promptText="dd/mm/yyyy" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            </GridPane>
            <Label text="Availability check: selected vehicle is available for the changed rental period."
                   style="-fx-text-fill: #159447; -fx-font-weight: bold;"/>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="18" maxWidth="1100">
            <Button text="Cancel Changes" onAction="#showBookingMenu" prefWidth="148" prefHeight="42"/>
            <Button text="Save Update" onAction="#handleUpdateBooking"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 16px; -fx-font-weight: bold;"
                    prefWidth="146" prefHeight="42"/>
        </HBox>
    </VBox>

    <VBox fx:id="cancelPage" spacing="24" visible="false" managed="false"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 42 54;">
        <Button text="Back" onAction="#showBookingMenu"
                style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                prefWidth="86" prefHeight="34"/>
        <VBox spacing="6" alignment="CENTER">
            <Label text="Cancel Booking" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="Find a scheduled booking and confirm cancellation" style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
        </VBox>
        <HBox spacing="18" maxWidth="980">
            <TextField fx:id="cancelSearchField" promptText="Customer name, phone, booking ID" prefWidth="360"/>
            <Button text="Find Booking" onAction="#handleSearchCancellableBookings"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                    prefWidth="150" prefHeight="42"/>
        </HBox>
        <TableView fx:id="cancelBookingsTable" prefHeight="150" maxWidth="980">
            <columns>
                <TableColumn fx:id="cancelBookingIdColumn" text="Booking ID" prefWidth="120"/>
                <TableColumn fx:id="cancelStartDateColumn" text="Start" prefWidth="180"/>
                <TableColumn fx:id="cancelEndDateColumn" text="End" prefWidth="180"/>
                <TableColumn fx:id="cancelStatusColumn" text="Status" prefWidth="140"/>
                <TableColumn fx:id="cancelVehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
            </columns>
        </TableView>
        <HBox alignment="CENTER_LEFT" spacing="18" maxWidth="980">
            <Label fx:id="cancelSelectionLabel" text="Select a booking to cancel"
                   style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 18 12 18; -fx-text-fill: #2f3338;"
                   maxWidth="Infinity"/>
            <Button text="Cancel Process" onAction="#showBookingMenu" prefWidth="140" prefHeight="42"/>
            <Button fx:id="confirmCancelBookingButton" text="Confirm Cancellation" onAction="#handleCancelBooking"
                    style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold;"
                    prefWidth="190" prefHeight="42"/>
        </HBox>
    </VBox>

    <VBox fx:id="completePage" spacing="24" visible="false" managed="false"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 42 54;">
        <Button text="Back" onAction="#showBookingMenu"
                style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                prefWidth="86" prefHeight="34"/>
        <VBox spacing="6" alignment="CENTER">
            <Label text="Complete / Return Booking" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="Close the active booking when the vehicle is returned" style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
        </VBox>
        <HBox spacing="18" maxWidth="980">
            <TextField promptText="Booking ID, customer, reg no" prefWidth="360"/>
            <Button text="Search" style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;" prefWidth="110" prefHeight="42"/>
        </HBox>
        <TableView fx:id="completeBookingsTable" prefHeight="150" maxWidth="980">
            <columns>
                <TableColumn fx:id="completeBookingIdColumn" text="Booking ID" prefWidth="120"/>
                <TableColumn fx:id="completeStartDateColumn" text="Start" prefWidth="180"/>
                <TableColumn fx:id="completeEndDateColumn" text="End" prefWidth="180"/>
                <TableColumn fx:id="completeStatusColumn" text="Status" prefWidth="140"/>
                <TableColumn fx:id="completeVehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
            </columns>
        </TableView>
        <Label text="Return UI placeholder. Complete booking logic already exists and can be connected in the next UI pass."
               style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 28; -fx-text-fill: #777777;"
               maxWidth="980"/>
    </VBox>

    <VBox fx:id="historyPage" spacing="24" visible="false" managed="false"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 42 54;">
        <Button text="Back" onAction="#showBookingMenu"
                style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
                prefWidth="86" prefHeight="34"/>
        <VBox spacing="6" alignment="CENTER">
            <Label text="Booking History / Archive" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
            <Label text="View read-only completed booking records" style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
        </VBox>
        <GridPane hgap="18" maxWidth="980">
            <columnConstraints>
                <ColumnConstraints percentWidth="24"/>
                <ColumnConstraints percentWidth="24"/>
                <ColumnConstraints percentWidth="22"/>
                <ColumnConstraints percentWidth="15"/>
                <ColumnConstraints percentWidth="15"/>
            </columnConstraints>
            <TextField fx:id="historyCustomerFilterField" promptText="Any customer" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="historyVehicleFilterField" promptText="Any vehicle" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <TextField fx:id="historyDateFilterField" promptText="YYYY-MM-DD" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Button text="Apply Filters" onAction="#handleApplyHistoryFilters" style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;" maxWidth="Infinity" prefHeight="42" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <Button text="Clear" onAction="#handleClearHistoryFilters" maxWidth="Infinity" prefHeight="42" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
        </GridPane>
        <TableView fx:id="historyBookingsTable" prefHeight="190" maxWidth="980">
            <columns>
                <TableColumn fx:id="historyBookingIdColumn" text="Booking ID" prefWidth="120"/>
                <TableColumn fx:id="historyStartDateColumn" text="Start" prefWidth="180"/>
                <TableColumn fx:id="historyEndDateColumn" text="End" prefWidth="180"/>
                <TableColumn fx:id="historyStatusColumn" text="Status" prefWidth="140"/>
                <TableColumn fx:id="historyVehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
            </columns>
        </TableView>
        <Label fx:id="historyDetailsLabel" text="Select an archived booking to view details." wrapText="true"
               style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 28; -fx-text-fill: #777777;"
               maxWidth="980"/>
    </VBox>

    <Label fx:id="statusLabel" StackPane.alignment="BOTTOM_CENTER"
           style="-fx-background-color: rgba(255,255,255,0.92); -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 18 8 18; -fx-text-fill: #2f3338;"/>
</StackPane>
