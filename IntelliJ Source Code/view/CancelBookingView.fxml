<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="cancelRoot" spacing="16" xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.CancelBookingController"
      style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 28 54;">
    <Button text="Back" onAction="#showBookingMenu"
            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
            prefWidth="86" prefHeight="34"/>
    <VBox spacing="6" alignment="CENTER">
        <Label text="Cancel Booking" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
        <Label text="Find a scheduled booking and confirm cancellation" style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
    </VBox>
    <HBox spacing="18" maxWidth="980">
        <TextField fx:id="cancelSearchField" promptText="Booking ID, customer ID, vehicle ID, status" prefWidth="360"/>
        <Button text="Find Booking" onAction="#handleFindBooking" style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;" prefWidth="150" prefHeight="42"/>
    </HBox>
    <TableView fx:id="cancelBookingsTable" prefHeight="240" minHeight="180" maxWidth="980" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="cancelBookingIdColumn" text="Booking ID" prefWidth="120"/>
            <TableColumn fx:id="cancelStartDateColumn" text="Start" prefWidth="180"/>
            <TableColumn fx:id="cancelEndDateColumn" text="End" prefWidth="180"/>
            <TableColumn fx:id="cancelStatusColumn" text="Status" prefWidth="140"/>
            <TableColumn fx:id="cancelVehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
        </columns>
    </TableView>
    <Button text="Cancel Selected Booking" onAction="#handleCancelSelectedBooking"
            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
            maxWidth="980" prefHeight="42"/>
    <Label fx:id="cancelStatusLabel"
           style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 18 12 18; -fx-text-fill: #777777;"
           maxWidth="980"/>
</VBox>
