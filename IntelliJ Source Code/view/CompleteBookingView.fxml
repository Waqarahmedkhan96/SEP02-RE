<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="completeRoot" spacing="16" xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.CompleteBookingController"
      style="-fx-background-color: #f7f7f7; -fx-border-color: #d5d5d5; -fx-padding: 22 54 28 54;">
    <Button text="Back" onAction="#showBookingMenu"
            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
            prefWidth="86" prefHeight="34"/>
    <VBox spacing="6" alignment="CENTER">
        <Label text="Complete / Return Booking" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2f3338;"/>
        <Label text="Close the active booking when the vehicle is returned" style="-fx-font-size: 15px; -fx-text-fill: #777777;"/>
    </VBox>
    <HBox spacing="18" maxWidth="980">
        <TextField fx:id="completeSearchField" promptText="Booking ID, customer ID, vehicle ID, status" prefWidth="360"/>
        <Button text="Search" onAction="#handleSearchBookings" style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;" prefWidth="110" prefHeight="42"/>
    </HBox>
    <TableView fx:id="completeBookingsTable" prefHeight="240" minHeight="180" maxWidth="980" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="completeBookingIdColumn" text="Booking ID" prefWidth="120"/>
            <TableColumn fx:id="completeStartDateColumn" text="Start Date" prefWidth="180"/>
            <TableColumn fx:id="completeEndDateColumn" text="End Date" prefWidth="180"/>
            <TableColumn fx:id="completeActualReturnColumn" text="Actual Return Date" prefWidth="180"/>
            <TableColumn fx:id="completeStatusColumn" text="Status" prefWidth="140"/>
            <TableColumn fx:id="completeVehicleIdColumn" text="Vehicle ID" prefWidth="120"/>
        </columns>
    </TableView>
    <Button text="Complete Selected Booking" onAction="#handleCompleteSelectedBooking"
            style="-fx-background-color: #050505; -fx-text-fill: #ffe600; -fx-border-color: #ffe600; -fx-border-radius: 5; -fx-background-radius: 5;"
            maxWidth="980" prefHeight="42"/>
    <Label fx:id="completeStatusLabel"
           style="-fx-background-color: white; -fx-border-color: #d8d8d8; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 12 18 12 18; -fx-text-fill: #777777;"
           maxWidth="980"/>
</VBox>
